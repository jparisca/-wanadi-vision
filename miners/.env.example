# ─── Nexus Prompt Miner — Variables de Entorno ──────────────────────────────
# Copia este archivo a .env y rellena los valores
# El scheduler y los mineros leen estas variables automáticamente.

# ─── Reddit OAuth (OPCIONAL — mejora el rate limit de 60 a 100 req/min) ──────
# Crear app en: https://www.reddit.com/prefs/apps (tipo: "script")
REDDIT_CLIENT_ID=TU_CLIENT_ID_AQUI
REDDIT_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
REDDIT_USERNAME=TU_USERNAME_DE_REDDIT
REDDIT_PASSWORD=TU_PASSWORD_DE_REDDIT

# ─── Civitai API (OPCIONAL — sin clave, pero con clave el rate limit es mayor) ─
# Obtener en: https://civitai.com/user/account → API Keys
CIVITAI_API_KEY=

# ─── Configuración del Scheduler ─────────────────────────────────────────────
# Intervalo en horas entre ciclos de ingestión (default: 12)
MINER_INTERVAL_HOURS=12

# Máximo de prompts por fuente por ciclo (controla uso de disco)
MINER_PROMPTS_PER_SOURCE=30
