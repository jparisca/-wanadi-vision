# ─── Nexus Prompt Bot — Variables de Entorno ─────────────────────────────────
# 1. Copia este archivo: cp bot/.env.example bot/.env
# 2. Rellena los valores a continuación
# 3. NUNCA subas el .env a git (ya está en .gitignore)

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Obtén tu token hablando con @BotFather en Telegram
# Comando: /newbot → sigue las instrucciones
BOT_TOKEN=TU_BOT_TOKEN_AQUI

# Tu chat ID personal para recibir notificaciones de venta
# Puedes obtenerlo escribiéndole a @userinfobot en Telegram
ADMIN_CHAT_ID=TU_CHAT_ID_AQUI

# ─── Backend ──────────────────────────────────────────────────────────────────
# URL de la API de Nexus Prompt (el servidor FastAPI)
# En producción, cambia esto por tu dominio o IP pública
NEXUS_API_URL=http://localhost:8000/api/v1
